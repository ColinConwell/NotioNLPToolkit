modules = ["python-3.11", "python3"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Jupyter Notebook"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Streamlit Demo"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "NotionNLP Example"

[[workflows.workflow]]
name = "Jupyter Notebook"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "jupyter notebook --ip=0.0.0.0 --port=8888 --no-browser --allow-root --NotebookApp.token='' --NotebookApp.password=''"
waitForPort = 8888

[[workflows.workflow]]
name = "Streamlit Demo"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m spacy download en_core_web_sm && streamlit run demo/streamlit_app.py --server.port 8501 --server.address 0.0.0.0 --server.enableCORS=false --server.enableXsrfProtection=false --server.baseUrlPath=''"
waitForPort = 8501

[[workflows.workflow]]
name = "NotionNLP Example"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python examples/check_access.py"

[deployment]
run = ["sh", "-c", "python -m spacy download en_core_web_sm && python examples/basic_usage.py"]

[[ports]]
localPort = 8501
externalPort = 3000

[[ports]]
localPort = 8888
externalPort = 80
