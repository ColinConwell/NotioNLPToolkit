
modules = ["python-3.11", "python3"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Streamlit Demo"
mode = "parallel"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash launch.sh --install-spacy"
waitForPort = 8501

[[ports]]
localPort = 8501
externalPort = 80

[deployment]
run = ["sh", "-c", "bash launch.sh"]
